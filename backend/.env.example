# SkillSetu — .env (SQLite version)
# ✅ SQLite needs NO database server — the file is created automatically!

# ── Required (just these 2 to start) ──────────────────
JWT_SECRET=skillsetu_secret_2024_change_this_in_production

# Get FREE Gemini key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Frontend URLs (don't change these) ────────────────
VITE_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ── Optional (add when you want these features) ───────

# Groq (free AI fallback): https://console.groq.com
GROQ_API_KEY=

# Twilio (WhatsApp + SMS): https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# Gmail alerts (use App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Cloudinary file uploads: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
